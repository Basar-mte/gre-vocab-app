DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# SMTP credentials used to send password-reset emails (src/lib/mail.ts).
# Any SMTP provider works: Gmail (with an app password), Zoho, SendGrid's
# SMTP relay, Resend's SMTP relay, your own domain's mailbox, etc.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="you@example.com"
SMTP_PASS="replace-with-smtp-password-or-app-password"
SMTP_FROM="GREasy <you@example.com>"
